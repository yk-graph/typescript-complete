{
  "compilerOptions": {
    // --- 出力設定 ---
    "target": "ES2022", // コンパイル後の JS バージョン
    "outDir": "./dist", // コンパイル後のファイルの出力先
    "rootDir": "./src", // ソースファイルのルートディレクトリ

    // --- 型チェック ---
    "strict": true, // 厳格な型チェックを有効化（noImplicitAny / strictNullChecks など8つをまとめて有効にする）
    "noUncheckedIndexedAccess": true, // 配列アクセス時に undefined の可能性を考慮させる（例: arr[0] が string | undefined になる）
    "noImplicitOverride": true, // override キーワードなしに親クラスのメソッドをオーバーライドするとエラーになる

    // --- モジュール解決 ---
    "module": "ES2022", // ブラウザ向けの ES モジュール形式を使用する（import/export 構文）
    "moduleResolution": "Bundler", // バンドラー向けのモジュール解決（ブラウザアプリに適切）

    // --- 利便性 ---
    "esModuleInterop": true, // CommonJS モジュールを import 構文で扱えるようにする
    "forceConsistentCasingInFileNames": true, // ファイル名の大文字小文字の一貫性を強制（Mac と Windows 間のバグ防止）
    "skipLibCheck": true, // node_modules の型チェックをスキップしてビルドを高速化
    "resolveJsonModule": true, // JSON ファイルを import できるようにする

    // --- デバッグ ---
    "sourceMap": true // ソースマップを生成。エラー発生時に dist/ の JS ではなく src/ の TS の行番号で確認できる
  },
  "include": ["src/**/*"], // src ディレクトリ以下の全ファイルをコンパイル対象にする
  "exclude": ["node_modules", "dist"] // 外部ライブラリとビルド済みファイルはコンパイル対象から除外する
}
